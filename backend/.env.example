# OpenAI API Key (required for GPT-4o-mini + embeddings)
OPENAI_API_KEY=your_openai_api_key_here
# Seconds for LLM HTTP requests (streaming + large RAG context); default 300
OPENAI_LLM_TIMEOUT=300

# PostgreSQL — use asyncpg for SQLAlchemy app + Alembic
# Example: postgresql+asyncpg://USER:PASSWORD@HOST/neondb?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/neet_assistant
# Asyncpg SSL mode for remote DB hosts: prefer|allow|require|verify-ca|verify-full|disable
DB_SSL_MODE=require

# pgvector table (LlamaIndex creates public.data_<name>)
PGVECTOR_TABLE_NAME=neet_assistant
EMBEDDING_DIM=1536

# Cloudflare R2 (S3-compatible) — PDF storage
R2_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET_NAME=neet-documents
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Optional: public URL prefix for downloads (e.g. https://pub-xxx.r2.dev or custom domain)
R2_PUBLIC_BASE_URL=

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Debug mode (set to false in production)
DEBUG=false

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# WhatsApp OTP webhook (required for auth OTP flow)
WHATSAPP_OTP_WEBHOOK=https://your-webhook-host/path

# FAQ short-circuit: cosine similarity must be >= this to skip RAG (typical matches 0.78–0.95)
FAQ_SCORE_THRESHOLD=0.85

# V2 rollout toggles (safe defaults)
# Enable async task wrapper for cutoff SQL routing classifier.
# Preferred flag name (clear scope):
V2_ASYNC_CUTOFF_ROUTER=false
# Backward-compat alias (legacy name; same behavior as V2_ASYNC_CUTOFF_ROUTER):
V2_PARALLEL_CLASSIFIERS=false
# If true, non-English questions are sent to core pipeline without pre-translation
# and model is instructed to respond directly in target language.
V2_DIRECT_NON_ENGLISH=false
